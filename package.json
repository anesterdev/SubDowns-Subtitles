{
  "name": "youtube-subtitle-downloader",
  "version": "1.0.0",
  "description": "YouTube Subtitle Downloader & MCP Server",
  "scripts": {
    "start": "node src/cli/download.ts",
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0",
    "build:client": "vite build",
    "build:server": "esbuild src/backend/server.ts --bundle --platform=node --packages=external --target=node24 --format=esm --outfile=dist/server.mjs --minify",
    "build": "npm run build:client && npm run build:server",
    "start:prod": "node dist/server.mjs",
    "api": "node src/backend/server.ts",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:api": "playwright test --project=api",
    "test:e2e:browser": "playwright test --project=browser",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@hono/zod-openapi": "^1.4.0",
    "@logtape/hono": "^2.2.1",
    "@logtape/logtape": "^2.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/hono-api-reference": "^0.11.4",
    "@vueuse/core": "^14.3.0",
    "entities": "^7.0.1",
    "hono": "^4.12.26",
    "hono-rate-limiter": "^0.5.3",
    "htmlparser2": "^12.0.0",
    "lru-cache": "^11.5.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.4",
    "vue3-toastify": "^0.2.9",
    "youtube-caption-extractor": "^1.10.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hono/vite-dev-server": "^0.26.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/test-utils": "^2.4.11",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  }
}
